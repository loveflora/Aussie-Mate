# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aussiemate
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=your_jwt_secret_key
